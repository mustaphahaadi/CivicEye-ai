{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile containing roles and metadata.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["citizen", "authority"] },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Report": {
      "title": "Incident Report",
      "description": "An incident reported by a citizen.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "location": { "type": "string" },
        "coordinates": { "type": "object" },
        "status": { "type": "string", "enum": ["pending", "investigating", "resolved", "dismissed"] },
        "reporterId": { "type": "string" },
        "reporterName": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "title", "description", "category", "location", "status", "reporterId", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment left on an incident report.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reportId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userRole": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "reportId", "userId", "userName", "text", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification sent to a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string" },
        "read": { "type": "boolean" }
      },
      "required": ["id", "userId", "title", "message", "createdAt", "read"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile collection"
    },
    "reports/{reportId}": {
      "schema": "Report",
      "description": "Citizen reports collection"
    },
    "comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments left on reports"
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Citizen notification system"
    }
  }
}
